{
  "auth_mode": "auto",
  "preferred_path": "oauth-session-wrapper-first",
  "env_fallback": {
    "enabled_by": "QUORUM_ROUTER_AUTH_MODE=env",
    "usage": "private manual fallback only"
  },
  "features": {
    "supabase": {
      "audit": {
        "mode": "disabled"
      }
    }
  },
  "cost_aware": {
    "enabled_by": "QUORUM_ROUTER_MAX_BUDGET_USD + QUORUM_ROUTER_ESTIMATED_COSTS_JSON",
    "pricing_source": "user-supplied estimates, not live billing"
  },
  "runtime_boundaries": {
    "best_route_direct": "production-ready best-answer routing",
    "agent_chat": "explicit opt-in conversation mode; no mutation authority",
    "safeloop_execution": "production-capable only with explicit execution authority and approval",
    "live_supabase_agent_bus_writes": false,
    "service_role_runtime": false
  }
}
